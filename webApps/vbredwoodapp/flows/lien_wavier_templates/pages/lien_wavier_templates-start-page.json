  "eventListeners": {
    "buttonAction": {
      "chains": [
        {
          "chain": "OpenButtonActionChain"
        }
      ]
    },
    "buttonAction2": {
      "chains": [
        {
          "chain": "CloseButtonActionChain"
        }
      ]
    },
    "buttonAction3": {
      "chains": [
