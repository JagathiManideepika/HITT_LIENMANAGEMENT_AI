          "chain": "CreateWaiverTemplateActionChain"
        }
      ]
    },
    "buttonAction4": {
      "chains": [
        {
          "chain": "SearchButtonActionChain"
        }
      ]
    },
    "buttonAction5": {
      "chains": [
        {
          "chain": "CloseViewButtonActionChain"
        }
      ]
    },
    "buttonAction6": {
      "chains": [
        {
          "chain": "DownloadTemplateAction"
        }
      ]
    },
    "buttonAction7": {
      "chains": [
        {
          "chain": "refreshButtonActionChain",
          "parameters": {
            "event": "{{$event}}",
            "originalEvent": "{{$event.detail.originalEvent}}"
          }
        }
      ]
    },
    "filePickerSelect": {
      "chains": [
        {
          "chain": "FilePickerSelectChain",
          "parameters": {
            "files": "[[ Array.prototype.slice.call($event.detail.files) ]]"
          }
        }
      ]
    },
    "iconClick": {
      "chains": [
        {
          "chain": "EditiconClickAction",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "iconClick2": {
      "chains": [
        {
          "chain": "updateRecordAction",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "selectValue": {
      "chains": [
        {
          "chain": "SelectValueChangeChain1",
          "parameters": {
            "value": "{{ $event.detail.value }}"
          }
        }
      ]
    },
    "selectValue2": {
      "chains": [
        {
          "chain": "statesLovActionChain",
          "parameters": {
            "value": "{{ $event.detail.value }}"
          }
        }
      ]
    },
    "selectValue3": {
      "chains": [
        {
          "chain": "statesLovActionChain1",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}"
          }
        }
      ]
    },
    "selectValueItem": {
      "chains": [
        {
          "chain": "TemplateTypeValueChangeAction",
          "parameters": {
            "key": "{{$event.detail.value.key}}",
            "data": "{{$event.detail.value.data}}",
            "metadata": "{{$event.detail.value.metadata}}"
          }
        }
      ]
    },
    "selectValueItem2": {
      "chains": [
        {
          "chain": "TemplateSelectValueItemChangeChain",
          "parameters": {
            "key": "{{$event.detail.value.key}}",
            "data": "{{$event.detail.value.data}}",
            "metadata": "{{$event.detail.value.metadata}}"
          }
        }
      ]
    },
    "spanClick": {
      "chains": [
        {
          "chain": "ViewClickChain",
          "parameters": {
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "switchValue": {
      "chains": [
        {
          "chain": "SwitchValueChangeChain",
          "parameters": {
            "value": "{{ $event.detail.value }}",
            "key": "{{ $current.key }}",
            "index": "{{ $current.index }}",
            "current": "{{ $current }}"
          }
        }
      ]
    },
    "switchValue2": {
      "chains": [
        {
          "chain": "SwitchValueChangeChain1",
          "parameters": {
            "event": "{{$event}}",
            "previousValue": "{{$event.detail.previousValue}}",
            "value": "{{ $event.detail.value }}",
            "updatedFrom": "{{$event.detail.updatedFrom}}"
          }
        }
      ]
    },
    "tableBeforeRowEdit": {
      "chains": [
        {
          "chain": "TemplateRowBeforeEdit",
          "parameters": {
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          }
        }
      ]
    },
    "tableBeforeRowEditEnd": {
      "chains": [
        {
          "chain": "TemplateTblBeforeRowEditEnd",
          "parameters": {
            "cancelEdit": "{{$event.detail.cancelEdit}}",
            "rowKey": "{{$event.detail.rowContext.status.rowKey}}",
            "rowIndex": "{{$event.detail.rowContext.status.rowIndex}}",
            "rowData": "{{$event.detail.rowContext.componentElement.getDataForVisibleRow($event.detail.rowContext.status.rowIndex).data}}"
          }
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "parameters": {},
          "chain": "SearchButtonActionChain"
        }
      ]
    }

