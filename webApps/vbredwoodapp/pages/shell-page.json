{
  "description": "",
  "routerFlow": "collaboration",
  "variables": {
    "currentFlow": {
      "type": "string"
    },
    "messageToast": {
      "type": "string"
    },
    "messagesBannerADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "itemType": "MessagesBannerType",
        "keyAttributes": "id"
      }
    },
    "messagesADP": {
      "type": "vb/ArrayDataProvider2",
      "defaultValue": {
        "keyAttributes": "id",
        "itemType": "page:messageType"
      }
    },
    "messageId": {
      "type": "number",
      "defaultValue": 1
    }
  },
  "metadata": {},
  "types": {
    "MessagesBannerType": {
      "id": "number",
      "messageType": "string",
      "primaryText": "string",
      "primaryActionLabel": "string",
      "secondaryText": "any",
      "secondaryActionLabel": "string"
    },
    "messageType": {
      "id": "string",
      "severity": "string",
      "category": "string",
      "summary": "string",
      "detail": "string",
      "timestamp": "string",
      "autoTimeout": "number"
    }
  },
  "eventListeners": {
    "application:spShowToast": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "showMessageToast"
        }
      ]
    },
    "buttonAction": {
      "chains": [
        {
          "chain": "application:toggleDrawerListener"
        }
      ]
    },
    "messagesBannerSpClose": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "closeMessageBanner"
        }
      ]
    },
    "navigationListSelection": {
      "chains": [
        {
          "chain": "navigationHandler",
          "parameters": {
            "selection": "{{ $event.detail.value }}",
            "currentFlow": "[[ $event.detail ]]"
          }
        }
      ]
    },
    "vbNotification": {
      "chains": [
        {
          "parameters": {
            "event": "{{ $event }}"
          },
          "chain": "showNotificationMessage"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-conveyor-belt": {
        "path": "ojs/ojconveyorbelt"
      },
      "oj-dialog": {
        "path": "ojs/ojdialog"
      },
      "oj-drawer-layout": {
        "path": "ojs/ojdrawerlayout"
      },
      "oj-drawer-popup": {
        "path": "ojs/ojdrawerpopup"
      },
      "oj-messages": {
        "path": "ojs/ojmessages"
      },
      "oj-navigation-list": {
        "path": "ojs/ojnavigationlist"
      },
      "oj-progress-bar": {
        "path": "ojs/ojprogress-bar"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-sp-messages-banner": {
        "path": "oj-sp/messages-banner/loader"
      },
      "oj-sp-messages-toast": {
        "path": "oj-sp/messages-toast/loader"
      }

    }
  },
  "translations": {}
}